# initialize or update chezmoi dotfiles
cm:
    $(op read op://homelab/svc/bash) \
    ; chezmoi init chrishenn -a --force \
    ; chezmoi update -a --force

# full upgrade of package manager packages
topgrade:
    $(op read op://homelab/svc/bash) \
    ; topgrade

# 'git clone' all repos for the default user. default dir: ~/
gclone:
    $(op read op://homelab/svc/bash) \
    ; ~/gclone.sh

# ssh into a remote, injecting op service account token into the remote shell
ssh usr ip port dir:
    ssh {{ usr }}@{{ ip }} -p {{ port }} -t "$(op read op://homelab/svc/bash) && cd {{ dir }} && exec bash -l"

rack0: (ssh "chris" "192.168.1.70"  "22"   "/home/chris/Projects/homelab/rack0")
rack4: (ssh "chris" "192.168.1.142" "2200" "/home/chris/Projects/homelab/rack4")
vps0:  (ssh "chris" env('VPS0_IP')  "2200" "/home/chris/Projects/homelab/vps0")
